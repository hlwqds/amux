[package]
name = "amux"
version = "0.2.0"
edition = "2024"

[dependencies]
anyhow = "1"
bytes = "1"
crossterm = "0.29"
portable-pty = "0.8"
ratatui = "0.30"
serde = { version = "1", features = ["derive"] }
serde_json = "1"
tui-term = "0.3.4"
vt100 = "0.16"
